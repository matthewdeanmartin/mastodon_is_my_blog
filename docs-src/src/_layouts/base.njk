<!DOCTYPE html>
<html lang="{{ lang }}">
  <head>
    {% include "head.njk" %}
  </head>

  <body>
    {% set sidebarArchive = stormArchives.authors | authorArchiveFor(sidebar_archive_acct) %}
    <div class="page">
      <div class="with-sidebar">
        <div>
          <div class="sidebar">
            <header role="banner" class="cluster">
              <div>
                <div class="sitelogo-parent">
                  <p class="sitelogo">
                    <a href="{{ '/' | relativeUrl(page.url) }}">{{ site.title or pkg.title }}</a>
                  </p>
                </div>
                <div>
                  {% include "components/navigation.njk" %}
                </div>
                {% if storms and storms.authors and storms.authors.length %}
                <section class="sidebar-section">
                  <p class="sidebar-title">Identities</p>
                  <ul class="sidebar-links">
                    {% for author in storms.authors %}
                    {% set authorUrl = '/authors/' + (author.acct | lower) + '/' %}
                    <li class="{% if sidebar_archive_acct and author.acct == sidebar_archive_acct %}current{% endif %}">
                      <a href="{{ authorUrl | relativeUrl(page.url) }}">@{{ author.acct }}</a>
                    </li>
                    {% endfor %}
                  </ul>
                </section>
                {% endif %}
                {% if sidebarArchive and sidebarArchive.months.length %}
                <section class="sidebar-section">
                  <p class="sidebar-title">Archive</p>
                  <ul class="sidebar-links">
                    <li class="{% if sidebarArchive.author.path == page.url %}current{% endif %}">
                      <a href="{{ sidebarArchive.author.path | relativeUrl(page.url) }}">Latest</a>
                    </li>
                    {% for month in sidebarArchive.months %}
                    <li class="{% if month.path == page.url or (sidebar_archive_month_path and month.path == sidebar_archive_month_path) %}current{% endif %}">
                      <a href="{{ month.path | relativeUrl(page.url) }}">{{ month.shortLabel }}</a>
                    </li>
                    {% endfor %}
                  </ul>
                </section>
                {% endif %}
              </div>
            </header>
          </div>
          <div class="not-sidebar">
            <main role="main">
              {% block content %}
                {{ content | safe }}
              {% endblock %}
            </main>
          </div>
        </div>
      </div>
      {% include "components/footer.njk" %}
    </div>
  </body>
</html>
