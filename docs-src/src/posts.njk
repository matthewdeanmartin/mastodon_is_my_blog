---
layout: base
pagination:
  data: storms.storms
  size: 1
  alias: storm
permalink: "/posts/{{ storm.slug }}/index.html"
eleventyComputed:
  title: "{{ storm.title }}"
  description: "{{ storm.excerpt }}"
  published_at: "{{ storm.created_at }}"
  sidebar_archive_acct: "{{ storm.author.acct }}"
  sidebar_archive_month_path: "{{ storm | stormMonthUrl }}"
---
{% from "partials/storm-tree.njk" import renderNode %}
{% set previousThread = storms.storms | previousStorm(storm.id) %}
{% set nextThread = storms.storms | nextStorm(storm.id) %}
<article class="storm-page">
  <header>
    <h1>{{ storm.title }}</h1>
    <div class="storm-meta">
      <span><a href="{{ ('/authors/' + (storm.author.acct | lower) + '/') | relativeUrl(page.url) }}">@{{ storm.author.acct }}</a></span>
      <time datetime="{{ storm.created_at }}">{{ storm.created_at | formatDate }}</time>
    </div>
  </header>

  <div class="storm-body">{{ storm.content_html | safe }}</div>

  {% if storm.media.length %}
  <div class="storm-media-grid">
    {% for media in storm.media %}
      {% if media.type == "image" %}
      <figure class="storm-media-item">
        <img src="{{ media.preview_url or media.url }}" alt="{{ media.description or '' }}">
      </figure>
      {% else %}
      <p class="storm-media-link"><a href="{{ media.url }}">Open {{ media.type }}</a></p>
      {% endif %}
    {% endfor %}
  </div>
  {% endif %}

  {% if storm.branches.length %}
  <section>
    <h2 class="storm-section-title">Self-replies</h2>
    {% for branch in storm.branches %}
      {{ renderNode(branch) }}
    {% endfor %}
  </section>
  {% endif %}

  <footer class="storm-actions">
    <a href="{{ storm.original_url }}">Comment</a>
  </footer>

  {% if previousThread or nextThread %}
  <nav class="thread-pagination" aria-label="Thread navigation">
    {% if previousThread %}
    <a class="thread-pagination-link" href="{{ ('/posts/' + previousThread.slug + '/') | relativeUrl(page.url) }}">Previous</a>
    {% endif %}
    {% if nextThread %}
    <a class="thread-pagination-link" href="{{ ('/posts/' + nextThread.slug + '/') | relativeUrl(page.url) }}">Next</a>
    {% endif %}
  </nav>
  {% endif %}
</article>
