{
  "name": "web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve web",
    "build": "ng build web",
    "build:lite": "ng build lite",
    "build:all": "npm run build && npm run build:lite",
    "build:lite:pages": "ng build lite --base-href /mastodon_is_my_blog/mimb_lite/",
    "start:lite": "ng serve lite",
    "watch": "ng build web --watch --configuration development",
    "test": "ng test web",
    "test:ci": "ng test web --no-watch --coverage && ng test lite --no-watch --coverage",
    "test:integration": "ng test web --configuration integration --no-watch",
    "lint": "ng lint web && ng lint lite --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,css}\"",
    "dead-code": "knip"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.18",
    "@angular/compiler": "^21.2.18",
    "@angular/core": "^21.2.18",
    "@angular/forms": "^21.2.18",
    "@angular/platform-browser": "^21.2.18",
    "@angular/router": "^21.2.18",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.18",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "jsdom": "^27.1.0",
    "knip": "^6.4.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
